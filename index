    function normalizeLangKey(str) {
      if (!str) return 'vietnam';
      const s = String(str).toLowerCase().trim();
      if (s.includes('viet') || s.includes('베트남') || s === 'vi') return 'vietnam';
      if (s.includes('chin') || s.includes('중국') || s === 'zh' || s === 'china') return 'china';
      if (s.includes('thai') || s.includes('태국') || s === 'th') return 'thailand';
      if (s.includes('mongol') || s.includes('몽골') || s === 'mn') return 'mongolia';
      if (s.includes('phil') || s.includes('필리핀') || s === 'ph' || s === 'tagalog') return 'philippines';
      if (s.includes('indo') || s.includes('인도네시아') || s === 'id') return 'indonesia';
      if (s.includes('cambod') || s.includes('캄보디아') || s === 'kh') return 'cambodia';
      if (s.includes('uzbek') || s.includes('우즈벡') || s === 'uz') return 'uzbek';
      if (s.includes('myan') || s.includes('미얀마') || s === 'mm') return 'myanmar';
      if (s.includes('bangla') || s.includes('방글라') || s === 'bd') return 'bangladesh';
      if (s.includes('nepal') || s.includes('네팔') || s === 'ne') return 'nepal';
      if (s.includes('lanka') || s.includes('스리랑카') || s === 'lk') return 'srilanka';
      if (s.includes('kyrgyz') || s.includes('키르기스') || s === 'kg') return 'kyrgyzstan';
      if (s.includes('pakis') || s.includes('파키스탄') || s === 'pk') return 'pakistan';
      if (s.includes('laos') || s.includes('라오스') || s === 'la') return 'laos';
      if (s.includes('timor') || s.includes('동티모르') || s === 'tl') return 'easttimor';
      if (s.includes('en') || s.includes('영')) return 'en';
      return 'vietnam';
    }

    function handleExcelUpload(event) {
      const file = event.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = function(e) {
        const data = new Uint8Array(e.target.result);
        const workbook = XLSX.read(data, { type: 'array' });
        const firstSheetName = workbook.SheetNames[0];
        const worksheet = workbook.Sheets[firstSheetName];
        
        const json = XLSX.utils.sheet_to_json(worksheet);
        if (!json || json.length === 0) {
          alert("엑셀 파일에 데이터가 없습니다.");
          return;
        }

        uploadedWorkerData = json.map(row => ({
          company: row['회사명'] || row['Company'] || '',
          name: row['근로자성명'] || row['근로자 성명'] || row['Name'] || '',
          nationality: row['국적'] || row['Nationality'] || '',
          dob: row['생년월일'] || row['DOB'] || '',
          idnum: row['신분증/여권번호'] || row['신분증번호'] || row['여권번호'] || row['ID'] || '',
          officer: row['확인자'] || row['담당자'] || row['Officer'] || '',
          lang: normalizeLangKey(row['언어코드'] || row['국적'] || row['Language'])
        }));

        const container = document.getElementById('worker-select-container');
        const dropdown = document.getElementById('worker-dropdown');
        container.classList.remove('hidden');
        container.classList.add('flex');

        let optionsHtml = `<option value="ALL">⚡ 전체 일괄 출력 모드 (총 ${uploadedWorkerData.length}명)</option>`;
        optionsHtml += uploadedWorkerData.map((w, idx) => 
          `<option value="${idx}">[${idx + 1}] ${w.name || '미입력'} (${w.nationality || '미입력'})</option>`
        ).join('');

        dropdown.innerHTML = optionsHtml;
        handleWorkerSelection("ALL");
      };
      reader.readAsArrayBuffer(file);
    }

    function handleWorkerSelection(value) {
      if (value === "ALL") {
        renderBatchPages();
      } else {
        renderSinglePage(parseInt(value, 10));
      }
    }

    function renderSinglePage(index) {
      const item = uploadedWorkerData[index];
      if (!item) return;

      document.getElementById('lang-select-wrapper').classList.remove('hidden');

      const container = document.getElementById('pages-container');
      container.innerHTML = generatePageHTML(item, item.lang);

      setLanguage(item.lang);
    }

    function renderBatchPages() {
      document.getElementById('lang-select-wrapper').classList.add('hidden');

      const container = document.getElementById('pages-container');
      container.innerHTML = uploadedWorkerData.map(item => generatePageHTML(item, item.lang)).join('');
    }

